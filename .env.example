# ============================================================
# M4ST v8.2-local — MASTER .env TEMPLATE
# Copy this to .env and fill in your actual keys
# NEVER commit .env to git (already in .gitignore)
# ============================================================

# ── 9Router ──────────────────────────────────────────────────
NINEROUTER_BASE_URL=http://localhost:20128/v1
NINEROUTER_API_KEY=your-9router-dashboard-key
NINEROUTER_MITM_PORT=20129

# ── LLM Models (set which model each chain uses) ─────────────
MODEL_FAST=groq/llama-3.3-70b-versatile
MODEL_DEEP=deepseek/deepseek-chat
MODEL_REASONING=deepseek/deepseek-reasoner

# ── Groq (Tier 3 free) ───────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ── DeepSeek (Tier 2 cheap — $0.028/1M) ─────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key

# ── NVIDIA NIM (Tier 3 free — 1000 credits on signup) ────────
NVIDIA_NIM_API_KEY=your-nvidia-nim-key
# Get at: build.nvidia.com — no credit card needed

# ── OpenCode / Kiro / Gemini API (Tier 3 free) ───────────────
GEMINI_API_KEY=your-gemini-api-key
# OPENCODE: uses Big Pickle server — no key needed if routing via 9Router

# ── SEPCC — Claude Code Session Proxy ────────────────────────
ANTHROPIC_BASE_URL=http://localhost:8082
ANTHROPIC_AUTH_TOKEN=freecc
FCC_AUTO_RESUME_LAST_SESSION=true

# ── Graphiti / FalkorDB ───────────────────────────────────────
FALKORDB_URI=bolt://localhost:6379
FALKORDB_USER=
FALKORDB_PASSWORD=
GRAPHITI_MCP_PORT=8001

# Embeddings via Gemini API (free)
GOOGLE_API_KEY=your-gemini-api-key

# ── Cognee MCP ────────────────────────────────────────────────
COGNEE_MCP_PORT=8000

# ── Langfuse (self-hosted) ────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_BASEURL=http://localhost:3000
LANGFUSE_OTEL_ENDPOINT=http://localhost:3000/api/public/otel

# ── OpenWork MCP Bridge ───────────────────────────────────────
M4ST_TOKEN=change-this-to-a-strong-random-token
OPENWORK_PORT=8765

# ── Telegram (for Uptime Kuma alerts + nightly reports) ───────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Composio MCP (cloud — connect.composio.dev) ───────────────
COMPOSIO_API_KEY=your-composio-api-key

# ── Exa Search MCP (1000 free calls/month) ───────────────────
EXA_API_KEY=your-exa-api-key
# Get at: exa.ai

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO=m4stanuj/m4st

# ── CrewAI ────────────────────────────────────────────────────
# No extra env needed — uses 9Router via NINEROUTER_BASE_URL above
